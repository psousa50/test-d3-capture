{
  "id": "9848473c-34b3-4e27-8b5b-ae0edfdb3985",
  "project_id": "20bcd0d5-677f-4470-828c-233cfc51e146",
  "feature_id": "49b783bf-7ad7-41fa-91f1-e726821b6a67",
  "type": "diagram:sharing-ui-mockup",
  "name": "Sharing UI Mockup",
  "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Transaction Sharing - UI Wireframe</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", \"Helvetica Neue\", sans-serif;\n            background-color: #f5f5f5;\n            padding: 20px;\n            line-height: 1.5;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n        }\n\n        h1 {\n            font-size: 24px;\n            margin-bottom: 30px;\n            color: #333;\n        }\n\n        .wireframe-section {\n            background: white;\n            border: 1px solid #ddd;\n            border-radius: 4px;\n            padding: 30px;\n            margin-bottom: 30px;\n        }\n\n        .section-title {\n            font-size: 18px;\n            font-weight: 600;\n            margin-bottom: 20px;\n            color: #333;\n            border-bottom: 2px solid #e0e0e0;\n            padding-bottom: 10px;\n        }\n\n        /* Main App Layout */\n        .app-layout {\n            display: grid;\n            grid-template-columns: 200px 1fr;\n            gap: 20px;\n            min-height: 600px;\n            background: #f9f9f9;\n            border: 1px solid #ddd;\n        }\n\n        .sidebar {\n            background: #f0f0f0;\n            border-right: 1px solid #ddd;\n            padding: 20px;\n        }\n\n        .menu-item {\n            padding: 12px;\n            margin-bottom: 8px;\n            border: 1px solid #ccc;\n            background: white;\n            font-size: 13px;\n            cursor: pointer;\n            border-radius: 2px;\n        }\n\n        .menu-item.active {\n            background: #e8f4f8;\n            border-left: 3px solid #0066cc;\n            padding-left: 9px;\n        }\n\n        .menu-item.highlight {\n            background: #fff3cd;\n            border: 1px solid #ffc107;\n        }\n\n        .main-content {\n            padding: 20px;\n            background: white;\n        }\n\n        /* Sharing Dialog/Modal */\n        .modal-overlay {\n            background: rgba(0, 0, 0, 0.3);\n            border: 1px solid #999;\n            padding: 20px;\n            margin-bottom: 20px;\n            border-radius: 4px;\n        }\n\n        .modal-header {\n            font-size: 16px;\n            font-weight: 600;\n            margin-bottom: 20px;\n            color: #333;\n        }\n\n        .form-group {\n            margin-bottom: 20px;\n        }\n\n        .form-label {\n            display: block;\n            font-size: 13px;\n            font-weight: 600;\n            margin-bottom: 6px;\n            color: #333;\n        }\n\n        .form-input, .form-select {\n            width: 100%;\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 2px;\n            font-size: 13px;\n            font-family: inherit;\n        }\n\n        .form-input:focus, .form-select:focus {\n            outline: none;\n            border-color: #0066cc;\n            box-shadow: 0 0 0 2px rgba(0, 102, 204, 0.1);\n        }\n\n        .account-selection {\n            margin-bottom: 15px;\n        }\n\n        .account-item {\n            display: flex;\n            align-items: center;\n            padding: 10px;\n            border: 1px solid #ddd;\n            border-radius: 2px;\n            margin-bottom: 8px;\n            background: #fafafa;\n        }\n\n        .account-item input[type=\"checkbox\"] {\n            margin-right: 12px;\n            cursor: pointer;\n        }\n\n        .account-item label {\n            flex: 1;\n            cursor: pointer;\n            font-size: 13px;\n            user-select: none;\n        }\n\n        .account-name {\n            font-weight: 600;\n            color: #333;\n        }\n\n        .account-balance {\n            color: #666;\n            font-size: 12px;\n        }\n\n        /* Buttons */\n        .button-group {\n            display: flex;\n            gap: 10px;\n            margin-top: 20px;\n        }\n\n        .button {\n            padding: 10px 16px;\n            border: 1px solid #ccc;\n            border-radius: 2px;\n            font-size: 13px;\n            font-weight: 600;\n            cursor: pointer;\n            background: white;\n            color: #333;\n            transition: all 0.2s;\n        }\n\n        .button:hover {\n            background: #f5f5f5;\n            border-color: #999;\n        }\n\n        .button.primary {\n            background: #0066cc;\n            color: white;\n            border-color: #0066cc;\n        }\n\n        .button.primary:hover {\n            background: #0052a3;\n            border-color: #0052a3;\n        }\n\n        .button.secondary {\n            background: #f0f0f0;\n            color: #333;\n        }\n\n        /* Shared Transactions View */\n        .shared-list {\n            margin-top: 15px;\n        }\n\n        .shared-item {\n            padding: 12px;\n            border: 1px solid #ddd;\n            border-radius: 2px;\n            margin-bottom: 10px;\n            background: #f9f9f9;\n            font-size: 13px;\n        }\n\n        .shared-header {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 6px;\n        }\n\n        .shared-email {\n            font-weight: 600;\n            color: #333;\n        }\n\n        .shared-date {\n            color: #999;\n            font-size: 12px;\n        }\n\n        .shared-accounts {\n            color: #666;\n            font-size: 12px;\n            margin-top: 6px;\n        }\n\n        .access-badge {\n            display: inline-block;\n            background: #e8f4f8;\n            color: #0066cc;\n            padding: 2px 8px;\n            border-radius: 2px;\n            font-size: 11px;\n            font-weight: 600;\n            margin-left: 8px;\n        }\n\n        /* Step-by-step flow */\n        .flow-step {\n            margin-bottom: 30px;\n            padding: 15px;\n            border-left: 4px solid #0066cc;\n            background: #f9f9f9;\n        }\n\n        .flow-step-title {\n            font-weight: 600;\n            margin-bottom: 10px;\n            color: #333;\n            font-size: 13px;\n        }\n\n        .flow-description {\n            color: #666;\n            font-size: 12px;\n            margin-bottom: 8px;\n        }\n\n        .flow-element {\n            background: white;\n            border: 1px solid #ddd;\n            padding: 10px;\n            border-radius: 2px;\n            margin-top: 8px;\n        }\n\n        .confirmation-box {\n            background: #e8f4f8;\n            border: 1px solid #0066cc;\n            padding: 15px;\n            border-radius: 2px;\n            margin: 15px 0;\n            font-size: 13px;\n        }\n\n        .confirmation-item {\n            margin: 6px 0;\n            color: #333;\n        }\n\n        .confirmation-item strong {\n            color: #0066cc;\n        }\n\n        /* Views section */\n        .view-tabs {\n            display: flex;\n            gap: 10px;\n            border-bottom: 1px solid #ddd;\n            margin-bottom: 20px;\n        }\n\n        .tab {\n            padding: 10px 16px;\n            border: 1px solid #ddd;\n            border-bottom: none;\n            background: #f5f5f5;\n            cursor: pointer;\n            font-size: 13px;\n            border-radius: 2px 2px 0 0;\n        }\n\n        .tab.active {\n            background: white;\n            border-top-color: #0066cc;\n            border-left-color: #0066cc;\n            border-right-color: #0066cc;\n            font-weight: 600;\n        }\n\n        .tab-content {\n            display: none;\n        }\n\n        .tab-content.active {\n            display: block;\n        }\n\n        /* Transaction table */\n        .transaction-table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 12px;\n        }\n\n        .transaction-table th {\n            background: #f0f0f0;\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n            font-weight: 600;\n            color: #333;\n        }\n\n        .transaction-table td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            color: #666;\n        }\n\n        .transaction-table tr:nth-child(even) {\n            background: #fafafa;\n        }\n\n        .amount {\n            text-align: right;\n            font-weight: 600;\n            color: #333;\n        }\n\n        .empty-state {\n            padding: 40px;\n            text-align: center;\n            color: #999;\n            background: #f9f9f9;\n            border: 1px dashed #ddd;\n            border-radius: 2px;\n        }\n\n        .empty-state-icon {\n            font-size: 32px;\n            margin-bottom: 10px;\n        }\n\n        .empty-state-text {\n            font-size: 13px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Transaction Sharing - UI Wireframe</h1>\n\n        <!-- Section 1: Share Transactions Flow -->\n        <div class=\"wireframe-section\">\n            <div class=\"section-title\">Step 1: Initiate Sharing - Dashboard View</div>\n            <div class=\"app-layout\">\n                <div class=\"sidebar\">\n                    <div class=\"menu-item active\">Dashboard</div>\n                    <div class=\"menu-item\">Accounts</div>\n                    <div class=\"menu-item\">Transactions</div>\n                    <div class=\"menu-item highlight\">Shared With Me</div>\n                    <div class=\"menu-item\">Settings</div>\n                </div>\n                <div class=\"main-content\">\n                    <div style=\"margin-bottom: 20px;\">\n                        <h3 style=\"font-size: 14px; margin-bottom: 10px;\">My Accounts</h3>\n                        <table class=\"transaction-table\">\n                            <thead>\n                                <tr>\n                                    <th>Account</th>\n                                    <th>Balance</th>\n                                    <th>Last Updated</th>\n                                    <th>Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                <tr>\n                                    <td>Checking</td>\n                                    <td>$5,234.50</td>\n                                    <td>Today</td>\n                                    <td><button class=\"button\" style=\"padding: 6px 12px; font-size: 12px;\">Share</button></td>\n                                </tr>\n                                <tr>\n                                    <td>Savings</td>\n                                    <td>$15,000.00</td>\n                                    <td>Today</td>\n                                    <td><button class=\"button\" style=\"padding: 6px 12px; font-size: 12px;\">Share</button></td>\n                                </tr>\n                                <tr>\n                                    <td>Investment</td>\n                                    <td>$8,750.25</td>\n                                    <td>Today</td>\n                                    <td><button class=\"button\" style=\"padding: 6px 12px; font-size: 12px;\">Share</button></td>\n                                </tr>\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- Section 2: Share Modal -->\n        <div class=\"wireframe-section\">\n            <div class=\"section-title\">Step 2: Share Dialog - Select Accounts & Enter Email</div>\n            <div class=\"modal-overlay\">\n                <div class=\"modal-header\">Share Your Transactions</div>\n                \n                <div class=\"form-group\">\n                    <label class=\"form-label\">Select Accounts to Share</label>\n                    <div class=\"account-selection\">\n                        <div class=\"account-item\">\n                            <input type=\"checkbox\" id=\"acc1\" checked>\n                            <label for=\"acc1\">\n                                <div class=\"account-name\">Checking</div>\n                                <div class=\"account-balance\">Balance: $5,234.50</div>\n                            </label>\n                        </div>\n                        <div class=\"account-item\">\n                            <input type=\"checkbox\" id=\"acc2\">\n                            <label for=\"acc2\">\n                                <div class=\"account-name\">Savings</div>\n                                <div class=\"account-balance\">Balance: $15,000.00</div>\n                            </label>\n                        </div>\n                        <div class=\"account-item\">\n                            <input type=\"checkbox\" id=\"acc3\">\n                            <label for=\"acc3\">\n                                <div class=\"account-name\">Investment</div>\n                                <div class=\"account-balance\">Balance: $8,750.25</div>\n                            </label>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"form-group\">\n                    <label class=\"form-label\">Recipient Email Address</label>\n                    <input type=\"email\" class=\"form-input\" placeholder=\"Enter email address (e.g., john@example.com)\">\n                    <div style=\"font-size: 11px; color: #999; margin-top: 6px;\">An invitation will be sent to this email address</div>\n                </div>\n\n                <div class=\"form-group\">\n                    <label class=\"form-label\">Permissions</label>\n                    <div style=\"padding: 10px; background: #f9f9f9; border: 1px solid #ddd; border-radius: 2px; font-size: 12px; color: #666;\">\n                        📖 Read-only access (cannot edit or delete transactions)\n                    </div>\n                </div>\n\n                <div class=\"button-group\">\n                    <button class=\"button secondary\">Cancel</button>\n                    <button class=\"button primary\">Send Invitation</button>\n                </div>\n            </div>\n        </div>\n\n        <!-- Section 3: Confirmation -->\n        <div class=\"wireframe-section\">\n            <div class=\"section-title\">Step 3: Confirmation Message</div>\n            <div class=\"confirmation-box\">\n                <div style=\"margin-bottom: 12px; font-weight: 600; color: #0066cc;\">✓ Invitation Sent Successfully</div>\n                <div class=\"confirmation-item\"><strong>Recipient:</strong> john@example.com</div>\n                <div class=\"confirmation-item\"><strong>Shared Accounts:</strong> Checking</div>\n                <div class=\"confirmation-item\"><strong>Access Level:</strong> Read-only</div>\n                <div class=\"confirmation-item\" style=\"margin-top: 12px; font-size: 11px; color: #666;\">The recipient will receive an email invitation and can access your shared transactions once they log in.</div>\n            </div>\n        </div>\n\n        <!-- Section 4: \"Shared With Me\" View -->\n        <div class=\"wireframe-section\">\n            <div class=\"section-title\">Recipient View: \"Shared With Me\" in Menu</div>\n            <div class=\"app-layout\">\n                <div class=\"sidebar\">\n                    <div class=\"menu-item\">Dashboard</div>\n                    <div class=\"menu-item\">Accounts</div>\n                    <div class=\"menu-item\">Transactions</div>\n                    <div class=\"menu-item active highlight\">Shared With Me</div>\n                    <div class=\"menu-item\">Settings</div>\n                </div>\n                <div class=\"main-content\">\n                    <h3 style=\"font-size: 14px; margin-bottom: 15px;\">Transactions Shared With You</h3>\n                    <div class=\"shared-list\">\n                        <div class=\"shared-item\">\n                            <div class=\"shared-header\">\n                                <div class=\"shared-email\">sarah.williams@example.com</div>\n                                <div class=\"shared-date\">Shared on Dec 15, 2024</div>\n                            </div>\n                            <div class=\"shared-accounts\">\n                                📁 Checking Account\n                                <span class=\"access-badge\">Read-only</span>\n                            </div>\n                        </div>\n                        <div class=\"shared-item\">\n                            <div class=\"shared-header\">\n                                <div class=\"shared-email\">michael.chen@example.com</div>\n                                <div class=\"shared-date\">Shared on Dec 10, 2024</div>\n                            </div>\n                            <div class=\"shared-accounts\">\n                                📁 Savings Account, 📁 Investment Account\n                                <span class=\"access-badge\">Read-only</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- Section 5: View Shared Transactions -->\n        <div class=\"wireframe-section\">\n            <div class=\"section-title\">View Shared Transactions - Detailed View</div>\n            <div style=\"padding: 15px; background: #f9f9f9; border: 1px solid #ddd; border-radius: 2px;\">\n                <div style=\"margin-bottom: 15px;\">\n                    <label class=\"form-label\" style=\"margin-bottom: 8px;\">From: sarah.williams@example.com</label>\n                    <select class=\"form-select\">\n                        <option>Checking Account</option>\n                    </select>\n                </div>\n\n                <div class=\"view-tabs\">\n                    <div class=\"tab active\">All Transactions</div>\n                    <div class=\"tab\">This Month</div>\n                    <div class=\"tab\">Last Month</div>\n                </div>\n\n                <div class=\"tab-content active\">\n                    <table class=\"transaction-table\">\n                        <thead>\n                            <tr>\n                                <th>Date</th>\n                                <th>Description</th>\n                                <th>Category</th>\n                                <th style=\"text-align: right;\">Amount</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            <tr>\n                                <td>Dec 20, 2024</td>\n                                <td>Grocery Store</td>\n                                <td>Food & Dining</td>\n                                <td class=\"amount\">-$124.50</td>\n                            </tr>\n                            <tr>\n                                <td>Dec 19, 2024</td>\n                                <td>Electric Company</td>\n                                <td>Utilities</td>\n                                <td class=\"amount\">-$89.75</td>\n                            </tr>\n                            <tr>\n                                <td>Dec 18, 2024</td>\n                                <td>Salary Deposit</td>\n                                <td>Income</td>\n                                <td class=\"amount\" style=\"color: #28a745;\">+$3,500.00</td>\n                            </tr>\n                            <tr>\n                                <td>Dec 17, 2024</td>\n                                <td>Coffee Shop</td>\n                                <td>Food & Dining</td>\n                                <td class=\"amount\">-$6.50</td>\n                            </tr>\n                            <tr>\n                                <td>Dec 16, 2024</td>\n                                <td>Gas Station</td>\n                                <td>Transportation</td>\n                                <td class=\"amount\">-$45.00</td>\n                            </tr>\n                        </tbody>\n                    </table>\n                </div>\n            </div>\n        </div>\n\n        <!-- Section 6: Account Selector with Sharing -->\n        <div class=\"wireframe-section\">\n            <div class=\"section-title\">Account Selector - Shows Only Shared Accounts</div>\n            <div style=\"padding: 15px; background: #f9f9f9; border: 1px solid #ddd; border-radius: 2px;\">\n                <label class=\"form-label\" style=\"margin-bottom: 10px;\">Select Account</label>\n                <select class=\"form-select\">\n                    <option>📁 Checking (from sarah.williams@example.com)</option>\n                    <option>📁 Savings (from michael.chen@example.com)</option>\n                    <option>📁 Investment (from michael.chen@example.com)</option>\n                </select>\n                <div style=\"margin-top: 12px; padding: 10px; background: #fff3cd; border: 1px solid #ffc107; border-radius: 2px; font-size: 12px; color: #333;\">\n                    💡 Only accounts shared with you appear in the dropdown. Your personal accounts are not shown here.\n                </div>\n            </div>\n        </div>\n\n        <!-- Section 7: Empty States -->\n        <div class=\"wireframe-section\">\n            <div class=\"section-title\">Empty States</div>\n            \n            <div style=\"margin-bottom: 20px;\">\n                <div style=\"font-size: 12px; font-weight: 600; margin-bottom: 10px; color: #666;\">When no transactions have been shared:</div>\n                <div class=\"empty-state\">\n                    <div class=\"empty-state-icon\">📤</div>\n                    <div class=\"empty-state-text\">No shared transactions yet</div>\n                    <div style=\"font-size: 11px; color: #999; margin-top: 6px;\">Share your accounts to collaborate with others</div>\n                </div>\n            </div>\n\n            <div>\n                <div style=\"font-size: 12px; font-weight: 600; margin-bottom: 10px; color: #666;\">When recipient hasn't received any shares:</div>\n                <div class=\"empty-state\">\n                    <div class=\"empty-state-icon\">📭</div>\n                    <div class=\"empty-state-text\">No transactions shared with you yet</div>\n                    <div style=\"font-size: 11px; color: #999; margin-top: 6px;\">Other users can share their accounts with you from their dashboard</div>\n                </div>\n            </div>\n        </div>\n\n    </div>\n</body>\n</html>",
  "updated_at": 1772719985025
}